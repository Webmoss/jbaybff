{
  "name": "jbaybff",
  "version": "0.1.0",
  "private": true,
  "description": "Jeffreys Bay Blue Flag Foundation — public web + admin dashboard monorepo",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "nx run-many -t build",
    "build:web": "nx build web",
    "build:admin": "nx build admin",
    "dev": "nx run-many -t dev --parallel=2",
    "dev:web": "nx dev web",
    "dev:admin": "nx dev admin",
    "start:web": "nx start web",
    "start:admin": "nx start admin",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "graph": "nx graph",
    "prisma:generate": "pnpm --filter @jbaybff/prisma prisma:generate",
    "prisma:migrate": "pnpm --filter @jbaybff/prisma prisma:migrate",
    "prisma:studio": "pnpm --filter @jbaybff/prisma prisma:studio",
    "prisma:seed": "pnpm --filter @jbaybff/prisma prisma:seed",
    "deploy:build": "node tools/deploy/xneelo-build.mjs",
    "deploy:pm2:start": "pm2 start ecosystem.config.cjs",
    "deploy:pm2:reload": "pm2 reload ecosystem.config.cjs",
    "deploy:pm2:logs": "pm2 logs",
    "postinstall": "pnpm prisma:generate || true"
  },
  "devDependencies": {
    "@nx/eslint": "20.3.0",
    "@nx/eslint-plugin": "20.3.0",
    "@nx/js": "20.3.0",
    "@nx/next": "20.3.0",
    "@nx/workspace": "20.3.0",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react": "^7.34.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "nx": "20.3.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "5.5.4"
  }
}
