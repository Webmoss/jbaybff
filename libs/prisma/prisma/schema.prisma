// =============================================================================
// JBay BFF — Prisma Schema
// -----------------------------------------------------------------------------
// Single source of truth for the Jeffreys Bay Blue Flag Foundation data model.
// Targets MySQL (Xneelo cPanel default) but stays compatible with PostgreSQL
// via the `DATABASE_PROVIDER` env var — see `libs/config/src/server.ts`.
//
// Conventions:
//   - All money values stored as integer minor units (cents) → ZAR cents.
//     This avoids floating-point drift in fundraising totals.
//   - `createdAt` / `updatedAt` on every persisted entity.
//   - Soft deletes via `deletedAt` only on entities we expect to retain for
//     audit/legal reasons (Donor, Donation, TaxCertificate, Order).
//   - cuid() is preferred over uuid() for shorter URLs and better index locality.
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  FULFILMENT
  TREASURER
  VIEWER
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DonationFrequency {
  ONCE
  MONTHLY
}

enum GiftTier {
  NONE
  TIER_1
}

enum CertificateStatus {
  REQUESTED
  GENERATED
  ISSUED
  REVOKED
}

enum OrderStatus {
  PENDING
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  PAYSTACK_CARD
  PAYSTACK_EFT
  MANUAL_EFT
  CASH
  OTHER
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum IdeaStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  REFUND
  ISSUE_CERTIFICATE
  MODERATE
  LOGIN
  LOGOUT
}

// -----------------------------------------------------------------------------
// Identity & access (admin dashboard)
// -----------------------------------------------------------------------------

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  role            UserRole  @default(EDITOR)
  passwordHash    String?
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  emailVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts              Post[]           @relation("PostAuthor")
  campaigns          Campaign[]       @relation("CampaignOwner")
  auditLogs          AuditLog[]
  certificatesIssued TaxCertificate[] @relation("CertificateIssuer")

  @@index([role])
  @@map("users")
}

// -----------------------------------------------------------------------------
// Donors & donations
// -----------------------------------------------------------------------------

model Donor {
  id        String  @id @default(cuid())
  email     String  @unique
  fullName  String
  phone     String?
  taxNumber String? // SA tax reference number (10 digits)
  idNumber  String? // SA ID/passport number (optional, for 18A)

  addressLine1 String?
  addressLine2 String?
  city         String?
  province     String?
  postalCode   String?
  country      String  @default("ZA")

  giftTier          GiftTier  @default(NONE)
  totalDonatedCents BigInt    @default(0)
  donationCount     Int       @default(0)
  lastDonatedAt     DateTime?

  consentMailingList Boolean   @default(false)
  consentMailingAt   DateTime?
  unsubscribedAt     DateTime?

  notes String? @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  donations           Donation[]
  taxCertificates     TaxCertificate[]
  orders              Order[]
  mailingSubscription MailingListSubscriber?

  @@index([giftTier])
  @@index([consentMailingList])
  @@index([deletedAt])
  @@map("donors")
}

model Donation {
  id      String @id @default(cuid())
  donorId String
  donor   Donor  @relation(fields: [donorId], references: [id], onDelete: Cascade)

  amountCents   BigInt // ZAR cents (always)
  currency      String            @default("ZAR")
  frequency     DonationFrequency @default(ONCE)
  status        DonationStatus    @default(PENDING)
  paymentMethod PaymentMethod     @default(PAYSTACK_CARD)

  // Paystack-specific
  paystackReference String?   @unique
  paystackTxnId     String?
  paystackPaidAt    DateTime?
  paystackChannel   String?
  paystackFeesCents BigInt?
  paystackRaw       Json?

  // Linkage
  campaignId     String?
  campaign       Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  giftOrderId    String?         @unique
  giftOrder      Order?          @relation("DonationGiftOrder", fields: [giftOrderId], references: [id], onDelete: SetNull)
  taxCertificate TaxCertificate?

  receiptNumber String? @unique
  notes         String? @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([campaignId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("donations")
}

// SARS Section 18A tax certificate (legal compliance)
// One certificate may aggregate multiple donations (year-end consolidation),
// but for v1 we issue one certificate per qualifying donation, per the brief.
model TaxCertificate {
  id                String            @id @default(cuid())
  certificateNumber String            @unique
  status            CertificateStatus @default(REQUESTED)

  donorId    String
  donor      Donor     @relation(fields: [donorId], references: [id], onDelete: Restrict)
  donationId String?   @unique
  donation   Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)

  // Snapshot the donor + org details at issue time so re-prints are immutable
  donorNameSnapshot  String
  donorTaxNumberSnap String?
  donorIdNumberSnap  String?
  donorAddressSnap   String? @db.Text

  amountCents  BigInt
  currency     String    @default("ZAR")
  donationDate DateTime
  issuedDate   DateTime?

  pboNumber        String // Public Benefit Org no. at time of issue
  organisationName String
  signatoryName    String
  signatoryTitle   String

  pdfPath     String? // local path on Xneelo disk
  pdfChecksum String? // SHA-256 of generated PDF

  issuedById String?
  issuedBy   User?   @relation("CertificateIssuer", fields: [issuedById], references: [id], onDelete: SetNull)

  revokedAt     DateTime?
  revokedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([donorId])
  @@index([status])
  @@index([donationDate])
  @@map("tax_certificates")
}

// -----------------------------------------------------------------------------
// E-commerce
// -----------------------------------------------------------------------------

model Product {
  id             String  @id @default(cuid())
  slug           String  @unique
  name           String
  shortDesc      String? @db.Text
  description    String? @db.LongText
  priceCents     BigInt // ZAR cents
  compareAtCents BigInt?
  sku            String? @unique
  inventory      Int     @default(0)
  isActive       Boolean @default(true)
  isGiftPackOnly Boolean @default(false) // tier-1 reward only

  weightGrams    Int?
  dimensionsJson Json?

  // SEO
  seoTitle       String?
  seoDescription String? @db.Text
  ogImageUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images     ProductImage[]
  variants   ProductVariant[]
  orderItems OrderItem[]
  categories ProductOnCategory[]

  @@index([isActive])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  position  Int     @default(0)
  motifId   String? // optional reference to libs/ui motif catalogue

  createdAt DateTime @default(now())

  @@index([productId, position])
  @@map("product_images")
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String // e.g. "T-shirt — Coral / M"
  sku        String? @unique
  priceCents BigInt? // overrides product price when set
  inventory  Int     @default(0)
  attributes Json? // { size: "M", color: "coral" }

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_variants")
}

model ProductCategory {
  id       String              @id @default(cuid())
  slug     String              @unique
  name     String
  parentId String?
  parent   ProductCategory?    @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductCategory[]   @relation("CategoryHierarchy")
  products ProductOnCategory[]

  createdAt DateTime @default(now())

  @@map("product_categories")
}

model ProductOnCategory {
  productId  String
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId String
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_on_category")
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  status      OrderStatus @default(PENDING)

  donorId String?
  donor   Donor?  @relation(fields: [donorId], references: [id], onDelete: SetNull)

  // contact + shipping
  email           String
  fullName        String
  phone           String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingPostal  String?
  shippingCountry String  @default("ZA")
  shippingNotes   String? @db.Text

  // pricing
  subtotalCents BigInt
  shippingCents BigInt @default(0)
  totalCents    BigInt

  // origin: was this auto-created by a Tier-1 gift, or a paid e-commerce order?
  isGiftOrder     Boolean   @default(false)
  paidViaDonation Donation? @relation("DonationGiftOrder")
  paidExternally  Boolean   @default(false)

  paystackReference String?   @unique
  trackingNumber    String?
  shippedAt         DateTime?
  deliveredAt       DateTime?

  internalNotes String? @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  items OrderItem[]

  @@index([status])
  @@index([donorId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  nameSnapshot   String // captured at order time for receipt fidelity
  skuSnapshot    String?
  unitPriceCents BigInt
  quantity       Int     @default(1)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_items")
}

// -----------------------------------------------------------------------------
// CMS — Posts (Blog) & Campaigns (Fundraising)
// -----------------------------------------------------------------------------

model Post {
  id            String     @id @default(cuid())
  slug          String     @unique
  title         String
  excerpt       String?    @db.Text
  body          String     @db.LongText
  coverImageUrl String?
  status        PostStatus @default(DRAFT)
  publishedAt   DateTime?

  authorId String?
  author   User?   @relation("PostAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  // SEO
  seoTitle       String?
  seoDescription String? @db.Text
  ogImageUrl     String?
  ogDescription  String? @db.Text
  canonicalUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags PostOnTag[]

  @@index([status, publishedAt])
  @@map("posts")
}

model Tag {
  id    String      @id @default(cuid())
  slug  String      @unique
  name  String
  posts PostOnTag[]

  createdAt DateTime @default(now())

  @@map("tags")
}

model PostOnTag {
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_on_tag")
}

model Campaign {
  id            String  @id @default(cuid())
  slug          String  @unique
  title         String
  shortDesc     String? @db.Text
  description   String? @db.LongText
  coverImageUrl String?
  motifId       String? // optional primary motif from libs/ui

  // Fundraising
  targetCents      BigInt // ZAR cents target
  raisedCentsCache BigInt @default(0) // denormalised, recomputed on donation events
  donorCountCache  Int    @default(0)

  startDate  DateTime?
  endDate    DateTime?
  status     CampaignStatus @default(DRAFT)
  isFeatured Boolean        @default(false)

  ownerId String?
  owner   User?   @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // SEO
  seoTitle       String?
  seoDescription String? @db.Text
  ogImageUrl     String?
  ogDescription  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donations Donation[]
  updates   CampaignUpdate[]

  @@index([status, isFeatured])
  @@map("campaigns")
}

model CampaignUpdate {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title       String
  body        String   @db.LongText
  publishedAt DateTime @default(now())

  @@index([campaignId, publishedAt])
  @@map("campaign_updates")
}

// -----------------------------------------------------------------------------
// Community Idea Board
// -----------------------------------------------------------------------------

model IdeaSubmission {
  id          String     @id @default(cuid())
  authorName  String // submitter's display name
  authorEmail String? // optional, never displayed publicly
  title       String
  body        String     @db.Text
  category    String? // free-form: "Cleanup", "Education", "Infrastructure", etc.
  status      IdeaStatus @default(PENDING)
  upvotes     Int        @default(0)

  moderatedAt   DateTime?
  moderatorNote String?   @db.Text
  publishedAt   DateTime?

  ipHash    String? // hashed IP for spam/dup detection (never raw)
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([publishedAt])
  @@map("idea_submissions")
}

// -----------------------------------------------------------------------------
// Transparent Fund Allocation
// -----------------------------------------------------------------------------

model FundAllocation {
  id          String  @id @default(cuid())
  slug        String  @unique
  label       String
  description String? @db.Text
  percentage  Decimal @db.Decimal(5, 2) // 0.00 - 100.00
  colorToken  String  @default("oceanBlue") // matches libs/ui PaletteKey
  position    Int     @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, position])
  @@map("fund_allocations")
}

// -----------------------------------------------------------------------------
// Mailing list & misc
// -----------------------------------------------------------------------------

model MailingListSubscriber {
  id       String  @id @default(cuid())
  email    String  @unique
  fullName String?
  source   String? // e.g. "donation-flow", "footer-form", "idea-board"
  donorId  String? @unique
  donor    Donor?  @relation(fields: [donorId], references: [id], onDelete: SetNull)

  externalId String? // id assigned by Mailchimp/Brevo etc., when synced
  syncedAt   DateTime?

  confirmedAt    DateTime?
  unsubscribedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([unsubscribedAt])
  @@map("mailing_list_subscribers")
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String // e.g. "Donation", "Post", "Campaign"
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("system_settings")
}
