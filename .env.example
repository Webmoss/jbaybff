# Single source of truth for local configuration (Docker + direct runs).

# ─── API (NestJS / Prisma / MySQL — Xneelo friendly) ───
DATABASE_URL="mysql://jbaybff:jbaybff@127.0.0.1:3306/jbaybff?connection_limit=5"
# Container-to-container URL used by docker compose:
DATABASE_URL_DOCKER="mysql://jbaybff:jbaybff@mysql:3306/jbaybff"
JWT_SECRET="change-me-in-production-min-32-chars-long"
JWT_EXPIRES_IN="7d"
PORT=3000
CORS_ORIGIN="http://localhost:5173"
SITE_URL="http://localhost:5173"
MAX_UPLOAD_MB=12
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="ChangeMeSoon!"

# ─── MySQL container bootstrap (docker compose mysql service) ───
MYSQL_ROOT_PASSWORD="root"
MYSQL_DATABASE="jbaybff"
MYSQL_USER="jbaybff"
MYSQL_PASSWORD="jbaybff"

# ─── Paystack (API) ───
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."
PAYSTACK_CALLBACK_URL="http://localhost:5173/donate/thanks"
PAYSTACK_RECURRING_CALLBACK_URL="http://localhost:5173/dashboard"
PAYSTACK_SHOP_CALLBACK_URL="http://localhost:5173/shop/thanks"
DONATIONS_RECURRING_RUNNER_ENABLED="false"
DONATIONS_RECURRING_RUNNER_INTERVAL_MS="900000"
DONATIONS_RECURRING_RUNNER_BATCH_SIZE="25"
DONATIONS_RECURRING_RUNNER_DRY_RUN="true"

# ─── WEB (Vue) ───
VITE_API_URL="http://localhost:3000/api"
VITE_ASSET_BASE="http://localhost:3000"

FEATURE_FLAG_RECURRING_DONATIONS="true"
FEATURE_FLAG_SPONSOR_IMPACT_SELF_SERVICE="true"
FEATURE_FLAG_ADMIN_SPONSOR_IMPACT_REPORTING="true"
FEATURE_FLAG_ADMIN_RECURRING_RUNNER="true"
FEATURE_FLAG_SHOP="true"
VITE_FEATURE_RECURRING_DONATIONS="true"
VITE_FEATURE_SPONSOR_IMPACT_SELF_SERVICE="true"
VITE_FEATURE_ADMIN_SPONSOR_IMPACT_REPORTING="true"
VITE_FEATURE_ADMIN_RECURRING_RUNNER="true"
VITE_FEATURE_SHOP="true"
