# =============================================================================
# JBay BFF — Environment Variables
# =============================================================================
# Copy this file to `.env` (local dev) and `.env.production` (Xneelo box).
# NEVER commit the populated files. See `libs/config/src/server.ts` for the
# Zod schema that validates these values at runtime.
# =============================================================================

# -- Runtime ------------------------------------------------------------------
NODE_ENV=development
APP_ENV=local                          # one of: local | staging | production
NEXT_PUBLIC_APP_ENV=local

# -- Public URLs --------------------------------------------------------------
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# -- Database (Xneelo MySQL or managed Postgres) ------------------------------
# Xneelo standard cPanel hosting includes MySQL. Choose `mysql` for cPanel,
# or `postgresql` if you provision a managed Postgres (e.g. Supabase / Neon).
DATABASE_PROVIDER=mysql
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/jbaybff?connection_limit=10"
# Optional shadow DB used by `prisma migrate dev`; not required in production.
DATABASE_SHADOW_URL=

# -- Authentication (admin app) -----------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
ADMIN_EMAIL_ALLOWLIST="admin@jbaybff.org.za,trustee@jbaybff.org.za"

# -- Paystack (ZAR + intl. card support) --------------------------------------
# Test keys start with `pk_test_` / `sk_test_`. Live keys start with `pk_live_`.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=

# -- Email (Xneelo SMTP per mailbox, or external SMTP) ------------------------
SMTP_HOST=mail.jbaybff.org.za
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@jbaybff.org.za
SMTP_PASSWORD=
SMTP_FROM="JBay BFF <noreply@jbaybff.org.za>"

# -- Newsletter provider hook -------------------------------------------------
# none | mailchimp | brevo | mailerlite
NEWSLETTER_PROVIDER=none
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# -- SARS Section 18A tax certificate metadata --------------------------------
ORG_LEGAL_NAME="Jeffreys Bay Blue Flag Foundation NPC"
ORG_REGISTRATION_NUMBER="2026/000000/08"
ORG_PBO_NUMBER="930000000"
ORG_TAX_REFERENCE="9000000000"
ORG_PHYSICAL_ADDRESS="Jeffreys Bay, Kouga Local Municipality, Eastern Cape, 6330, South Africa"
ORG_CONTACT_EMAIL=info@jbaybff.org.za
ORG_CONTACT_PHONE="+27 00 000 0000"
TAX_CERTIFICATE_SIGNATORY_NAME="Authorised Signatory"
TAX_CERTIFICATE_SIGNATORY_TITLE="Trustee"

# -- Storage paths (relative to app cwd on Xneelo) ----------------------------
STORAGE_DIR=./storage
TAX_CERTIFICATE_DIR=./storage/tax-certificates

# -- Feature flags ------------------------------------------------------------
FEATURE_IDEA_BOARD=true
FEATURE_ECOMMERCE=true
FEATURE_TAX_CERTIFICATES=true

# -- Donation tier threshold (ZAR) --------------------------------------------
TIER_1_GIFT_THRESHOLD_ZAR=1000
